# ===========================================
# Hoard - Environment Configuration
# ===========================================
# Copy this to .env.local (dev) or .env.production (deploy)
# NEVER commit .env.local or .env.production to git

# Database
DATABASE_URL=./data/hoard.db

# Steam API
# Get your key at: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=
STEAM_USER_ID=

# IsThereAnyDeal API (Phase 2)
# Register your app at: https://isthereanydeal.com/dev/app/
ITAD_API_KEY=

# Discord Notifications (Phase 5)
# Create a webhook in your Discord server settings
DISCORD_WEBHOOK_URL=

# Authentication
# Generate secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# Comma-separated list of additional trusted origins for auth (e.g. your reverse proxy URL)
TRUSTED_ORIGINS=

# App Configuration
APP_URL=http://localhost:3000
CRON_PRICE_CHECK=0 */12 * * *
CRON_LIBRARY_SYNC=0 3 * * *
# Nightly ITAD price history backfill (100 games per run, ~100s wall time)
CRON_PRICE_HISTORY_BACKFILL=0 5 * * *

# Notifications
# Fallback minimum hours between alerts for the same game (Settings → Notifications
# overrides this once saved). Default: 24.
ALERT_THROTTLE_HOURS=24
# Server timezone. Quiet hours (Settings → Notifications) and cron schedules are
# evaluated in this zone. Defaults to UTC; set to your local zone, e.g. America/New_York.
TZ=UTC
