# ===========================================
# Hoard - Environment Configuration
# ===========================================
# Copy this to .env.local (dev) or .env.production (deploy)
# NEVER commit .env.local or .env.production to git

# Database
DATABASE_URL=./data/hoard.db

# Steam API
# Get your key at: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=
STEAM_USER_ID=

# IsThereAnyDeal API (Phase 2)
# Register your app at: https://isthereanydeal.com/dev/app/
ITAD_API_KEY=

# Discord Notifications (Phase 5)
# Create a webhook in your Discord server settings
DISCORD_WEBHOOK_URL=

# Secret-settings encryption (field-level, at-rest)
# Encrypts the secret values in the `settings` table (Steam/ITAD API keys + both
# Discord webhook URLs) so they are not stored in plaintext in the SQLite file or
# backups. Values written while this is set are tagged `enc:v1:`; existing
# plaintext rows stay readable (non-bricking). If UNSET, secrets are read/written
# as plaintext with a logged warning (transition-safe). Any passphrase works
# (stretched with scrypt). Generate one with: openssl rand -base64 32
# NOTE: keep this stable — losing it makes already-encrypted secrets unreadable.
# SETTINGS_ENCRYPTION_KEY is accepted as an alias.
HOARD_SECRETS_KEY=

# Authentication
# Generate secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# Comma-separated list of additional trusted origins for auth (e.g. your reverse proxy URL)
TRUSTED_ORIGINS=

# App Configuration
APP_URL=http://localhost:3000
CRON_PRICE_CHECK=0 */12 * * *
CRON_LIBRARY_SYNC=0 3 * * *
# Nightly ITAD price history backfill (100 games per run, ~100s wall time)
CRON_PRICE_HISTORY_BACKFILL=0 5 * * *

# Notifications
# Fallback minimum hours between alerts for the same game (Settings → Notifications
# overrides this once saved). Default: 24.
ALERT_THROTTLE_HOURS=24
# Hour (0-23, in the server's TZ below) for the once-daily "still at all-time low"
# digest. Price checks still run on CRON_PRICE_CHECK (so new-ATL alerts fire as often
# as that), but the still-at-ATL reminder is consolidated to the first run on/after
# this hour each day. This is only the seed default — Settings → Notifications lets you
# change it in-app. Default 12 (= 8 AM US Eastern under the default TZ=UTC container).
ATL_DIGEST_HOUR=12
# Server timezone. Quiet hours (Settings → Notifications) and cron schedules are
# evaluated in this zone. Defaults to UTC; set to your local zone, e.g. America/New_York.
TZ=UTC
